# AWS config for the nix-configs devShell.
# This file is used exclusively inside `nix develop` — AWS_CONFIG_FILE is pointed here
# by the shellHook so that host profiles do not interfere.
#
# Credentials are never stored here — they are injected at runtime via `op read`
# in the justfile recipes. This profile only sets the region.
#
# Future: once IAM Identity Center is configured, use Granted (`assume`) to generate
# profiles from SSO and update this file accordingly. See SPEC.md roadmap item 13.

[profile nix-configs]
region = eu-central-1
